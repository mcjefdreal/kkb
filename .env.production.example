# Reference template for production deployment.
# Copy this to `.env` on your server and fill in the real values.
# The Dockerfile bakes PUBLIC_CONVEX_URL at build time from the DOMAIN below,
# so it is NOT required in this file.

# Your public domain, bare host with no scheme and no trailing slash.
DOMAIN=kkb.example.com

# Convex Cloud deployment URLs. Include the scheme, no trailing slash.
# These are passed to Caddy as upstream addresses.
CONVEX_CLOUD_URL=https://upbeat-axolotl-779.convex.cloud
CONVEX_SITE_URL=https://upbeat-axolotl-779.convex.site

# Optional: ports Caddy binds on the host.
# HTTP_PORT=80
# HTTPS_PORT=443

# Convex backend environment variables (set on the production deployment):
# npx convex env set SITE_URL https://kkb.example.com
# npx convex env set BETTER_AUTH_SECRET <openssl rand -base64 32>
# npx convex env set GOOGLE_CLIENT_ID <your-prod-google-client-id>
# npx convex env set GOOGLE_CLIENT_SECRET <your-prod-google-client-secret>
# npx convex env set BOT_API_KEY <random-string>

# CLI configuration on the machine that deploys Convex code (NOT the server):
# .env.local
# CONVEX_DEPLOYMENT=prod:upbeat-axolotl-779
